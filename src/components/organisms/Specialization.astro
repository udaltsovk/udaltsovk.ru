---
import Technology from "../molecules/Technology.svelte";
import type { Specialization } from "../../consts.ts";

type Props = Specialization;

const { name, accent_color, technologies } = Astro.props;
---

<section>
  <h3>{name}</h3>
  <div class="technologies">
    {
      technologies.map((technology) => (
        <Technology client:only="svelte" {...technology} />
      ))
    }
  </div>
</section>

<style>
  section {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .technologies {
    width: 100%;
    gap: 1rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-column-gap: 1rem;
  }

  @media (max-width: 1000px) {
    .technologies {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 630px) {
    .technologies {
      grid-template-columns: 1fr;
    }
  }
</style>
