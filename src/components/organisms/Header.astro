---
import { SITE_TITLE } from "../../consts";
import HeaderLink from "../atoms/HeaderLink.astro";
import SocialLinks from "../molecules/SocialLinks.astro";
---

<header>
  <nav>
    <a href="/">
      <div class="logo">
        <img alt="favicon" src="/logo.webp" width="48" height="48/" />
        <h2>{SITE_TITLE}</h2>
      </div>
    </a>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog (TODO)</HeaderLink>
    </div>
    <div class="social-links">
      <SocialLinks />
    </div>
  </nav>
</header>

<style lang="less">
  @import (reference) "../../styles/tokens.less";

  @header-shadow-color: fade(#11111b, 5%);

  header {
    position: sticky;
    top: 0;
    margin: 0;
    padding: 0 @space-md;
    background-color: @color-mantle;
    box-shadow: 0 @space-2xs @space-sm @header-shadow-color;
    z-index: @z-header;

    h2 {
      margin: 0;
      font-size: @font-size-site-title;

      a,
      a.active {
        text-decoration: none;
      }
    }

    nav {
      .flex-between();

      a {
        padding: @space-md @space-sm;
        color: @color-text;
        border-bottom: @space-xs solid transparent;
        text-decoration: none;

        &.active {
          text-decoration: none;
          border-bottom-color: @color-accent;
        }
      }
    }

    .logo {
      display: flex;
      align-items: center;
      gap: @space-sm;
    }

    @media (max-width: @breakpoint-page) {
      .social-links {
        display: none;
      }
    }
  }
</style>
